{
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/auth/index.js":    { "memory": 128, "maxDuration": 10 },
    "api/auth/callback.js": { "memory": 128, "maxDuration": 10 }
  },
  "rewrites": [
    { "source": "/api/auth",          "destination": "/api/auth/index.js"    },
    { "source": "/api/auth/callback", "destination": "/api/auth/callback.js" }
  ],
  "headers": [
    {
      "source": "/admin",
      "headers": [
        { "key": "Content-Security-Policy", "value": "default-src * 'unsafe-inline' 'unsafe-eval' data: blob:; script-src * 'unsafe-inline' 'unsafe-eval' blob:; connect-src * data: blob:; img-src * data: blob:; frame-src *; style-src * 'unsafe-inline'; font-src * data:;" },
        { "key": "X-Frame-Options", "value": "ALLOWALL" }
      ]
    },
    {
      "source": "/admin/:path*",
      "headers": [
        { "key": "Content-Security-Policy", "value": "default-src * 'unsafe-inline' 'unsafe-eval' data: blob:; script-src * 'unsafe-inline' 'unsafe-eval' blob:; connect-src * data: blob:; img-src * data: blob:; frame-src *; style-src * 'unsafe-inline'; font-src * data:;" },
        { "key": "X-Frame-Options", "value": "ALLOWALL" }
      ]
    },
    {
      "source": "/api/auth",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" }
      ]
    },
    {
      "source": "/api/auth/:path*",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" }
      ]
    },
    {
      "source": "/:path*",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-XSS-Protection",        "value": "1; mode=block" },
        { "key": "Referrer-Policy",         "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/:path*.(css|js|woff2|woff|ttf|otf|eot)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/:path*.(jpg|jpeg|png|gif|webp|svg|ico)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400" }]
    }
  ],
  "redirects": [
    { "source": "/blog/adherencia-procesos.html",    "destination": "/blog/adherencia-procesos",    "permanent": true },
    { "source": "/blog/ia-vs-orden.html",            "destination": "/blog/ia-vs-orden",            "permanent": true },
    { "source": "/blog/importancia-documentar.html", "destination": "/blog/importancia-documentar", "permanent": true },
    { "source": "/blog/index.html",                  "destination": "/blog",                        "permanent": true },
    { "source": "/index.html",                       "destination": "/",                            "permanent": true }
  ]
}
